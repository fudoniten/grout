{:log-level #or [#env GROUT_LOG_LEVEL :info]
 :server {:port #or [#env GROUT_HTTP_PORT 8080]}

 ;; DATABASE_URL is the GROUT.md §11 name; the GROUT_-prefixed vars take
 ;; precedence for ops isolation when both are set.
 :database {:jdbc-url  #or [#env GROUT_DATABASE_URL #env DATABASE_URL
                            "jdbc:postgresql://localhost:5432/grout"]
            :username  #or [#env GROUT_DATABASE_USER "grout"]
            :password  #or [#env GROUT_DATABASE_PASS "grout"]}

 :media {:media-dir #or [#env GROUT_MEDIA_DIR "/data/media/grout"]
         ;; Playout profile for intake normalization (GROUT.md §8).
         :profile {:vcodec "h264"
                   :pix-fmt "yuv420p"
                   :acodec "aac"
                   :sample-rate 48000
                   :channels 2
                   :audio-bitrate "192k"}}

 ;; Tunabrain: typed, purposeful endpoints (see
 ;; /opt/data/home/docs/grout-tunabrain-enrichment-requirements.md).
 ;; Grout calls /categorize + /tags — NOT the OpenAI chat-completions
 ;; shape. No :chat-path key.
 :tunabrain {:endpoint #or [#env TUNABRAIN_URL "http://tunabrain:8080"]
             :model #or [#env GROUT_TUNABRAIN_MODEL "openrouter/auto"]
             :timeout-ms 30000}

 ;; Tunarr Scheduler: source of the dimensions catalog. At startup we
 ;; fetch GET /api/dimensions + GET /api/dimensions/{name}/values from
 ;; this service and pass the result to Tunabrain's /categorize call.
 ;; If TUNARR_SCHEDULER_URL is unset, the enrichment orchestrator
 ;; starts with an empty catalog (log a warning; enrichment still
 ;; works for the free-form-tags path).
 :tunarr-scheduler {:endpoint #or [#env TUNARR_SCHEDULER_URL ""]}

 ;; Natural-language descriptions for each dimension, fed to
 ;; Tunabrain's /categorize `CategoryDefinition`. Tunarr Scheduler
 ;; does not expose descriptions; we ship them in the Grout config.
 ;; Keep these in sync with tunarr-scheduler/src/.../config.edn when
 ;; a new dimension is added.
 :dimension-descriptions {:audience "Audience segments this media is appropriate for (kids, teen, family, adult)"
                         :channel  "Tunarr Scheduler channels this media can play on (e.g. britannia, goldenreels, toontown)"
                         :freshness "How recent this media is (e.g. fresh, current, classic, archival)"
                         :season    "Seasonal slot this media fits (e.g. summer, holiday, evergreen)"
                         :time-slot "Broadcast time-slot this media fits (e.g. morning, prime-time, late-night)"}

 ;; Async metadata enrichment sweep (GROUT.md §9).
 :enrichment {:enabled #or [#env GROUT_ENRICHMENT_ENABLED true]
              :interval-ms 60000
              :batch-size 10}

 ;; Directory-level (tag-group) enrichment: one Tunabrain /enrich/profile call
 ;; derives a shared dimensions+tags profile per parent-directory tag and fans
 ;; it out to every child item, replacing per-file enrichment for bulk imports.
 ;; The worker sweeps directory_profiles; sample-count is how many filenames it
 ;; samples per group to ground the LLM call.
 :directory-enrichment {:enabled #or [#env GROUT_DIRECTORY_ENRICHMENT_ENABLED true]
                        :interval-ms 60000
                        :batch-size 10
                        :sample-count 5}

 ;; Retention caps per (channel, kind, duration-bucket) (GROUT.md §10).
 :retention {:enabled #or [#env GROUT_RETENTION_ENABLED true]
             :interval-ms 3600000
             :cap 20
             :bucket-ms 5000}}
